# PQC Key Generator Environment Variables

DEBUG=false                     # Enable debug mode
IMAGE_NAME=pqckeygen            # Image tag for the container build/output
TMP_TTL_SEC=5                   # Time (in seconds) after which the temporary directory and files (including the DER key) are auto-deleted
KEYGEN_FORMAT=DER               # Output format for generated key (DER, PEM, ...). Must match supported format handlers.
KEYGEN_ALGORITHM=ML-KEM-512     # PQC algorithm to use for key generation. Overridden by CLI --key/-k.
KEYGEN_KEYPAIR=false            # Enable keypair mode (PEM + DER export). Set to 'true' to activate keypair mode. When enabled, KEYGEN_FORMAT and --format parameter are ignored.
