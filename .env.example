# Enable debug mode
DEBUG=false

# Image tag for the container build/output
IMAGE_NAME=pqckeygen

# Directory used for key output volume
TMP=keygen_tmp

# Time (in seconds) after which the temporary directory and files (including the DER key) are auto-deleted
TMP_TTL_SEC=5

# Output format for generated key (DER, PEM, ...). Must match supported format handlers.
KEYGEN_FORMAT=DER

# PQC algorithm to use for key generation. Overridden by CLI --key/-k.
KEYGEN_ALGORITHM=ML-KEM-512

# Set to 'docker' or 'podman' to override engine autodetection, leave empty to auto-select.
CONTAINER_ENGINE=

# Enable keypair mode (PEM + DER export). Set to 'true' to activate keypair mode.
# When enabled, KEYGEN_FORMAT and --format parameter are ignored.
KEYGEN_KEYPAIR=false
